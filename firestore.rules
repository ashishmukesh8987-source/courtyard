rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: get user role
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return request.auth != null && getUserData().role == "admin";
    }

    function isShopOwner() {
      return request.auth != null && getUserData().role == "shop_owner";
    }

    // --- Courtyards ---
    match /courtyards/{courtyardId} {
      allow read: if true;
      allow create: if isAdmin();
      allow update, delete: if isAdmin() && resource.data.adminUid == request.auth.uid;
    }

    // --- Shops ---
    match /shops/{shopId} {
      allow read: if true;
      allow create: if isAdmin();
      allow update: if request.auth != null
        && (
          isAdmin()
          || (isShopOwner() && getUserData().shopId == shopId)
        );
      allow delete: if isAdmin();
    }

    // --- Menu Items ---
    match /menuItems/{itemId} {
      allow read: if true;
      allow create: if request.auth != null
        && (
          isAdmin()
          || (isShopOwner() && getUserData().shopId == request.resource.data.shopId)
        );
      allow update, delete: if request.auth != null
        && (
          isAdmin()
          || (isShopOwner() && getUserData().shopId == resource.data.shopId)
        );
    }

    // --- Orders ---
    match /orders/{orderId} {
      // Create: anyone (customers have no auth), but validate required fields
      allow create: if request.resource.data.keys().hasAll(['shopId', 'courtyardId', 'customerName', 'customerPhone', 'tableNumber', 'items', 'total', 'status'])
        && request.resource.data.status == 'pending'
        && request.resource.data.items.size() > 0
        && request.resource.data.items.size() <= 50
        && request.resource.data.total > 0
        && request.resource.data.customerName is string
        && request.resource.data.customerName.size() >= 1
        && request.resource.data.customerName.size() <= 100
        && request.resource.data.customerPhone is string
        && request.resource.data.customerPhone.size() >= 10
        && request.resource.data.customerPhone.size() <= 15;

      // Read: shop owners can read their orders, admins can read all in their courtyard
      allow read: if request.auth != null
        && (
          isAdmin()
          || (isShopOwner() && getUserData().shopId == resource.data.shopId)
        );

      // Update: only shop owners (their orders) and admins
      allow update: if request.auth != null
        && (
          isAdmin()
          || (isShopOwner() && getUserData().shopId == resource.data.shopId)
        )
        // Only allow status and updatedAt to be changed
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt']);
    }

    // --- Users ---
    match /users/{userId} {
      // Users can read their own doc
      allow read: if request.auth != null && request.auth.uid == userId;
      // Users can update their own doc (e.g. switch active courtyard)
      allow update: if request.auth != null && request.auth.uid == userId;
      // Admins can read and write any user
      allow read, write: if isAdmin();
    }
  }
}
